# C++ Core Guidelines + modern C++ enforcement for graph_slam
# Place at the package root (graph_slam/) or repo root (drone-graph-slam/).
Checks: >
  -*,
  cppcoreguidelines-*,
  modernize-*,
  performance-*,
  bugprone-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-magic-numbers,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-identifier-length,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay
WarningsAsErrors: ''
HeaderFilterRegex: 'graph_slam/include/graph_slam/.*'
FormatStyle: file
